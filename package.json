{
  "name": "@orchestra-mcp/theme",
  "version": "1.0.0",
  "description": "Color themes and CSS variables for Orchestra MCP \u2014 Tailwind CSS v4",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./src/styles/base.css",
    "./themes": {
      "import": "./dist/themes.mjs",
      "require": "./dist/themes.js",
      "types": "./dist/themes.d.ts"
    },
    "./variants": {
      "import": "./dist/variants.mjs",
      "require": "./dist/variants.js",
      "types": "./dist/variants.d.ts"
    },
    "./theme-switcher": {
      "import": "./dist/theme-switcher.mjs",
      "require": "./dist/theme-switcher.js",
      "types": "./dist/theme-switcher.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/orchestra-mcp/theme"
  },
  "funding": "https://github.com/sponsors/fadymondy",
  "license": "MIT",
  "dependencies": {
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-alpha.30"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "tsup src/index.ts src/theme-switcher.ts src/themes.ts src/variants.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "orchestra",
    "mcp",
    "react",
    "components",
    "theme"
  ]
}
